{
  "name": "cade",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "postinstall": "patch-package",
    "typecheck": "tsc --noEmit",
    "test:phrase": "node scripts/test-phrase-matching.ts",
    "generate-sounds": "node scripts/generate-sounds.js",
    "fetch-vosk-model": "node scripts/fetch-vosk-model.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-voice/voice": "^3.2.4",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-av": "~15.1.4",
    "expo-dev-client": "~5.2.4",
    "expo-document-picker": "~13.1.5",
    "expo-file-system": "~18.1.10",
    "expo-intent-launcher": "~12.1.4",
    "expo-keep-awake": "~14.1.4",
    "expo-linking": "~7.1.5",
    "expo-notifications": "~0.31.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-headphone-detection": "^1.3.0",
    "react-native-volume-manager": "^2.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "adm-zip": "^0.5.17",
    "patch-package": "^8.0.1",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "@react-native-voice/voice": {
      "@expo/config-plugins": "~10.1.2"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-voice/voice",
          "expo-av",
          "react-native-headphone-detection"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
